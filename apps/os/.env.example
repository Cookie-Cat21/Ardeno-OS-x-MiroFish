# ============================================================
# Ardeno OS – Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ─── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ─── Canva Pro (Connect API) ──────────────────────────────────
# Get from: https://www.canva.com/developers/
# Scopes needed: design:read design:write export:write
# SECURITY: This token is client-visible. For production,
# route Canva API calls through a Supabase Edge Function.
VITE_CANVA_ACCESS_TOKEN=your-canva-oauth-token

# ─── Telegram Bot ─────────────────────────────────────────────
# Create bot via @BotFather → get token
# SECURITY: Client-visible. Use Edge Function proxy in prod.
VITE_TELEGRAM_BOT_TOKEN=your-bot-token
VITE_TELEGRAM_GROUP_ID=your-group-or-chat-id

# ─── GitHub ───────────────────────────────────────────────────
# Personal Access Token with repo scope
# SECURITY: Client-visible. Use Edge Function proxy in prod.
VITE_GITHUB_TOKEN=ghp_your-personal-access-token
VITE_GITHUB_REPO=ArdenoStudio/ardeno-os
